{
  "name": "foremoz-workspace-root",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "install:all": "npm --prefix ./eventdb/mvp-node install && npm --prefix ./foremoz/apps/api install && npm --prefix ./foremoz/apps/vite install && npm --prefix ./passport/apps/api install",
    "setup:all": "npm run setup:fitness && npm run setup:passport",
    "setup:fitness": "node ./scripts/workspace.mjs setup fitness",
    "setup:passport": "node ./scripts/workspace.mjs setup passport",
    "dev:fitness": "node ./scripts/workspace.mjs dev fitness",
    "dev:fitness:mockup": "VITE_APP_MODE=mock VITE_MOCKUP_OPEN_ACCESS=true node ./scripts/workspace.mjs dev fitness",
    "dev:passport": "node ./scripts/workspace.mjs dev passport",
    "dev:passport:mockup": "VITE_APP_MODE=mock VITE_MOCKUP_OPEN_ACCESS=true node ./scripts/workspace.mjs dev passport",
    "dev:all": "node ./scripts/workspace.mjs dev all",
    "dev:all:mockup": "VITE_APP_MODE=mock VITE_MOCKUP_OPEN_ACCESS=true node ./scripts/workspace.mjs dev all"
  }
}
