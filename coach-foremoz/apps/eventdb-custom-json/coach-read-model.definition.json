{
  "name": "foremoz-coach-read-model-v1",
  "namespace_format": "foremoz:coach:<tenant_id>",
  "chain_format": "branch:<branch_id>|core",
  "checkpoint_table": "read.rm_checkpoint",
  "tables": [
    {
      "name": "read.rm_coach_profile_public",
      "primary_key": ["tenant_id", "coach_id"],
      "columns": ["tenant_id", "coach_id", "coach_handle", "display_name", "bio", "status", "updated_at"],
      "query_use": "render coach microsite profile"
    },
    {
      "name": "read.rm_coach_offer_catalog",
      "primary_key": ["tenant_id", "offer_id"],
      "columns": ["tenant_id", "offer_id", "coach_id", "offer_name", "price_amount", "status", "updated_at"],
      "query_use": "offer list for subscribe flow"
    },
    {
      "name": "read.rm_location_class_list",
      "primary_key": ["tenant_id", "class_id"],
      "columns": ["tenant_id", "class_id", "coach_id", "location_id", "studio_id", "start_at", "capacity", "booked_count", "updated_at"],
      "query_use": "join class by location"
    },
    {
      "name": "read.rm_subscription_funnel",
      "primary_key": ["tenant_id", "funnel_id"],
      "columns": ["tenant_id", "funnel_id", "coach_id", "source_channel", "share_count", "click_count", "subscribe_count", "booking_count", "updated_at"],
      "query_use": "channel conversion metrics"
    },
    {
      "name": "read.rm_invitation_queue",
      "primary_key": ["tenant_id", "invitation_id"],
      "columns": ["tenant_id", "invitation_id", "inviter_actor_kind", "invitee_actor_kind", "target_contact", "channel", "status", "updated_at"],
      "query_use": "pending invitation state"
    },
    {
      "name": "read.rm_actor_network",
      "primary_key": ["tenant_id", "relation_id"],
      "columns": ["tenant_id", "relation_id", "left_actor_kind", "left_actor_id", "right_actor_kind", "right_actor_id", "status", "source_invitation_id", "updated_at"],
      "query_use": "coach-member-studio graph"
    },
    {
      "name": "read.rm_support_team",
      "primary_key": ["tenant_id", "team_member_id"],
      "columns": ["tenant_id", "team_member_id", "coach_id", "role_name", "location_scope", "is_active", "updated_at"],
      "query_use": "support team management"
    },
    {
      "name": "read.rm_coach_performance",
      "primary_key": ["tenant_id", "coach_id", "performance_date"],
      "columns": ["tenant_id", "coach_id", "performance_date", "new_subscriber_count", "class_occupancy_rate", "retention_rate", "updated_at"],
      "query_use": "coach KPI dashboard"
    },
    {
      "name": "read.rm_pricing_plan_state",
      "primary_key": ["tenant_id", "coach_id"],
      "columns": ["tenant_id", "coach_id", "plan_code", "plan_status", "effective_at", "updated_at"],
      "query_use": "pricing tier and billing state"
    }
  ]
}
