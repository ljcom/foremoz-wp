VITE_APP_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3300
VITE_MOCKUP_OPEN_ACCESS=false
STAGE=4
PRELAUNCH=1
# Stage rollout:
# 1 = fitness only (disable language, passport, /events)
# 2 = open all verticals
# 3 = open passport and /events
# 4 = open language
