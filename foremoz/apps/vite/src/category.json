    ]
  },
  "decision_guide": [
    {
      "question": "Is this the main type of activity shown in catalog and reports?",
      "use": "category"
    },
    {
      "question": "Is this only a supporting SEO, search, or discovery label?",
      "use": "tag"
    },
    {
      "question": "Does this affect award, leaderboard, or participant grouping?",
      "use": "division"
    },
    {
      "question": "Is this only a day, slot, agenda item, or rundown segment?",
      "use": "session"
    }
  ]
}
